    "@dqbd/tiktoken": "^1.0.22",
    "@google-cloud/storage": "^7.21.0",
    "@mendable/firecrawl-rs": "workspace:*",
    "@openrouter/ai-sdk-provider": "^2.9.1",
    "@sentry/cli": "^2.58.2",
    "@sentry/node": "^10.27.0",
    "@types/ws": "^8.5.12",
    "ai": "6.0.86",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "amqplib": "^0.10.9",
    "async-mutex": "^0.5.0",
