    "@types/supertest": "^6.0.2",
    "@types/tough-cookie": "^4.0.5",
    "husky": "^9.1.7",
    "knip": "^5.70.1",
    "lint-staged": "^16.1.6",
    "supertest": "^6.3.3",
    "tsc-watch": "^7.1.1",
    "tsx": "^4.20.3",
    "undici-types": "^7.16.0",
    "vitest": "^4.1.9"
  },
