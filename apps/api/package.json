    "axios": "^1.18.0",
    "body-parser": "^1.20.3",
    "bullmq": "^5.56.7",
    "cacheable-lookup": "^6.1.0",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "culori": "^4.0.2",
    "diff": "^8.0.3",
    "dotenv": "^16.3.1",
    "drizzle-orm": "1.0.0-rc.3",
