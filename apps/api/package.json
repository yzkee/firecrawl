    "typescript": "npm:@typescript/typescript6@6.0.2",
    "typescript-7": "npm:typescript@7.0.2",
    "undici": "7.28.0",
    "uuid": "^13.0.1",
    "winston": "^3.14.2",
    "ws": "^8.21.0",
    "xml2js": "^0.6.2",
    "zod": "4.1.12"
  },
  "nodemonConfig": {
    "ignore": [
      "*.docx",
      "*.json",
      "temp"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md}": "prettier --write"
  },
  "packageManager": "pnpm@11.4.0"
}
